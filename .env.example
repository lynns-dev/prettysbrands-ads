# Redis connection string (Redis Cloud, or any provider that gives you a
# redis:// / rediss:// URL) — holds admin sessions, brand configs, and the
# Meta Ads token/adjustment history.
REDIS_URL=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for this app (there's no public storefront — the whole thing is
# the admin tool). Sessions are stored in Redis above.
ADMIN_PASSWORD=

# Meta (Facebook) app with the Marketing API product added, ads_management +
# ads_read requested under App Review. One shared connection is authorized
# once via /api/meta-auth/connect and used across every brand's ad account
# (the authorizing Facebook user needs admin access to each one) — see README.
META_APP_ID=
META_APP_SECRET=

# Any random string (e.g. `openssl rand -hex 16`) — restricts the daily
# auto-adjust cron job to Vercel's own scheduled calls.
CRON_SECRET=

# Anthropic API key — powers "Winner detection" and "Performance trends &
# recommendation" (Claude analyzes ad/day-level performance and produces a
# recommendation). Only needed if you use those features; get one at
# console.anthropic.com.
ANTHROPIC_API_KEY=

# Web Push (phone notifications for pacing alerts). Generate a pair with:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY must be the SAME value —
# one is read server-side, the other is inlined into the browser bundle.
# VAPID_PRIVATE_KEY must stay secret (never commit it, never put it in
# NEXT_PUBLIC_*). Only needed if you want the "Enable phone notifications"
# button to work.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# mailto: address push services can contact if something's wrong with this
# integration. Optional, defaults to a placeholder.
VAPID_SUBJECT=mailto:you@example.com
