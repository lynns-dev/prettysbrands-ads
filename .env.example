# Redis connection string (Redis Cloud, or any provider that gives you a
# redis:// / rediss:// URL) — holds admin sessions, brand configs, and the
# Meta Ads token.
REDIS_URL=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for this app (there's no public storefront — the whole thing is
# the admin tool). Sessions are stored in Redis above.
ADMIN_PASSWORD=

# Meta (Facebook) app with the Marketing API product added, ads_management +
# ads_read requested under App Review. One shared connection is authorized
# once via /api/meta-auth/connect and used across every brand's ad account
# (the authorizing Facebook user needs admin access to each one) — see README.
META_APP_ID=
META_APP_SECRET=

# Optional. A static secret that lets an external caller (a script, a
# Shortcut, an agent filling in drafts on your behalf) create brands and
# save "new creative" drafts without a browser login session — send it as
# `Authorization: Bearer <value>`. Scoped narrowly: it can list/create
# brands and save drafts, but NOT publish a draft, change brand settings,
# or delete anything — those stay session-only. Leave unset to disable
# this entirely. Generate one with `openssl rand -hex 24`.
DRAFTS_API_KEY=

